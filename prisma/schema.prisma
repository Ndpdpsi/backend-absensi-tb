generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum StatusAbsensi {
  HADIR
  IZIN
  SAKIT
  ALPHA
}

model Siswa {
  id             String   @id @default(uuid()) @db.Char(36)
  NISN           Int      @unique
  NIPD           Int      @unique
  nama_siswa     String
  alamat         String
  gender         String   @db.Char(1)
  tanggal_lahir  DateTime @db.Date
  nomor_telepon  String   @db.VarChar(15)
  orangtua_id    Int?
  kelas_id       Int?

  orang_tua      orang_tua? @relation(fields: [orangtua_id], references: [id])
  kelas          Kelas?     @relation(fields: [kelas_id], references: [id])
  rfid           RFID[]
  absensi        AbsensiSiswa[]

  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  @@index([kelas_id])
  @@index([orangtua_id])
}

model orang_tua {
  id             Int      @id @default(autoincrement())
  nama_orangtua  String
  nomor_telepon  String   @db.VarChar(15)

  siswa          Siswa[]

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  deleted_at     DateTime?
}

model RFID {
  id         Int      @id @default(autoincrement())
  uid_rfid   Int      @unique
  siswa_id   String   @db.Char(36)
  is_active  Boolean  @default(true)

  siswa      Siswa    @relation(fields: [siswa_id], references: [id])
  absensi    AbsensiSiswa[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  @@index([siswa_id])
}

model AbsensiSiswa {
  id         Int      @id @default(autoincrement())
  siswa_id   String   @db.Char(36)
  tanggal    DateTime @db.Date
  tap_in     Int?
  tap_out    Int?
  rfid_id    Int?

  siswa      Siswa @relation(fields: [siswa_id], references: [id])
  rfid       RFID? @relation(fields: [rfid_id], references: [id])
  detail     DetailAbsensiSiswa[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  @@index([siswa_id, tanggal])
  @@index([rfid_id])
}

model DetailAbsensiSiswa {
  id          Int           @id @default(autoincrement())
  absensi_id  Int
  jadwal_id   Int
  guru_id     Int
  status      StatusAbsensi
  jam_absen   DateTime
  keterangan  String?       @db.Text

  absensi     AbsensiSiswa @relation(fields: [absensi_id], references: [id])
  jadwal      Jadwal       @relation(fields: [jadwal_id], references: [id])
  guru        Guru         @relation(fields: [guru_id], references: [id])

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?

  @@index([absensi_id])
  @@index([jadwal_id])
  @@index([guru_id])
}

model Guru {
  id             Int       @id @default(autoincrement())
  NIP            Int       @unique
  nama           String
  nomor_telepon  String    @db.VarChar(15)
  alamat         String
  tanggal_lahir  DateTime? @db.Date

  jadwal         Jadwal[]
  detail_absensi DetailAbsensiSiswa[]

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  deleted_at     DateTime?
}

model Jadwal {
  id             Int      @id @default(autoincrement())
  tanggal_jadwal DateTime @db.Date
  kelas_id       Int
  mapel_id       Int
  guru_id        Int
  jam_mulai      DateTime @db.Time
  jam_selesai    DateTime @db.Time

  kelas          Kelas         @relation(fields: [kelas_id], references: [id])
  mata_pelajaran MataPelajaran @relation(fields: [mapel_id], references: [id])
  guru           Guru          @relation(fields: [guru_id], references: [id])
  detail_absensi DetailAbsensiSiswa[]

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  deleted_at     DateTime?

  @@index([kelas_id, tanggal_jadwal])
  @@index([guru_id, tanggal_jadwal])
  @@index([mapel_id])
}

model MataPelajaran {
  id         Int      @id @default(autoincrement())
  nama_mapel String

  jadwal     Jadwal[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
}

model Kelas {
  id              Int      @id @default(autoincrement())
  kelas           String
  jurusan_id      Int
  tahun_ajaran_id Int

  jurusan         Jurusan @relation(fields: [jurusan_id], references: [id])
  tahun           Tahun   @relation(fields: [tahun_ajaran_id], references: [id])
  siswa           Siswa[]
  jadwal          Jadwal[]

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?

  @@index([jurusan_id])
  @@index([tahun_ajaran_id])
  @@unique([kelas, jurusan_id, tahun_ajaran_id])
}

model Jurusan {
  id           Int      @id @default(autoincrement())
  nama_jurusan String   @unique

  kelas        Kelas[]

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  deleted_at   DateTime?
}

model Tahun {
  id           Int      @id @default(autoincrement())
  tahun_ajaran String   @unique

  kelas        Kelas[]

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  deleted_at   DateTime?
}