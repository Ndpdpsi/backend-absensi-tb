generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusAbsensi {
  HADIR
  IZIN
  SAKIT
  ALPHA
}

enum StatusKedatangan {
  TELAMBAT
  TEPAT_WAKTU
}

enum Gender {
  L
  P
}

enum Hari {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
}

enum Role {
  ADMIN
  GURU
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique
  password String
  role     Role

  guru_id Int? @unique
  guru    Guru? @relation(fields: [guru_id], references: [id], onDelete: SetNull)

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@index([deleted_at])
  @@map("users")
}



model Siswa {
  id            String   @id @default(uuid()) @db.Uuid
  NISN          String   @unique
  NIPD          String   @unique
  nama          String
  alamat        String
  gender        Gender
  tanggal_lahir DateTime @db.Date
  nomor_telepon String
  orangtua_id   Int?
  kelas_id      Int?

  orang_tua OrangTua? @relation(fields: [orangtua_id], references: [id], onDelete: SetNull)
  kelas     Kelas?    @relation(fields: [kelas_id], references: [id], onDelete: SetNull)
  rfid      RFID[]
  absensi   AbsensiSiswa[]

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@index([kelas_id])
  @@index([orangtua_id])
  @@index([deleted_at])
  @@map("siswa")
}


model OrangTua {
  id            Int    @id @default(autoincrement())
  nama_orangtua String @db.VarChar(255)
  nomor_telepon String @db.VarChar(15)
  telegram_id   String @db.VarChar(50) 

  siswa Siswa[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@index([deleted_at])
  @@index([telegram_id])
  @@map("orang_tua")
}

model RFID {
  id        Int     @id @default(autoincrement())
  uid_rfid  String  @unique @db.VarChar(50)
  siswa_id  String  @db.Uuid
  is_active Boolean @default(true)

  siswa   Siswa          @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  absensi AbsensiSiswa[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@index([siswa_id])
  @@index([is_active])
  @@index([deleted_at])
  @@map("rfid")
}

model AbsensiSiswa {
  id           Int               @id @default(autoincrement())
  siswa_id     String            @db.Uuid
  tanggal      DateTime          @db.Date
  tap_in       DateTime?         @db.Timestamptz(6)
  tap_out      DateTime?         @db.Timestamptz(6)
  rfid_id      Int?
  status_tapin StatusKedatangan?

  siswa  Siswa                @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  rfid   RFID?                @relation(fields: [rfid_id], references: [id], onDelete: SetNull)
  detail DetailAbsensiSiswa[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([siswa_id, tanggal])
  @@index([tanggal])
  @@index([rfid_id])
  @@index([status_tapin])
  @@index([deleted_at])
  @@map("absensi_siswa")
}

model DetailAbsensiSiswa {
  id         Int           @id @default(autoincrement())
  absensi_id Int
  jadwal_id  Int
  guru_id    Int
  status     StatusAbsensi
  jam_absen  DateTime      @db.Timestamptz(6)
  keterangan String?       @db.Text

  absensi AbsensiSiswa @relation(fields: [absensi_id], references: [id], onDelete: Cascade)
  jadwal  Jadwal       @relation(fields: [jadwal_id], references: [id], onDelete: Restrict)
  guru    Guru         @relation(fields: [guru_id], references: [id], onDelete: Restrict)

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([absensi_id, jadwal_id])
  @@index([jadwal_id])
  @@index([guru_id])
  @@index([status])
  @@index([deleted_at])
  @@map("detail_absensi_siswa")
}

model Guru {
  id            Int    @id @default(autoincrement())
  NIP           String @unique
  nama          String
  nomor_telepon String
  alamat        String
  tanggal_lahir DateTime?

  user User?

  jadwal         Jadwal[]
  detail_absensi DetailAbsensiSiswa[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@map("guru")
}


model Jadwal {
  id          Int      @id @default(autoincrement())
  hari        Hari
  kelas_id    Int
  mapel_id    Int
  guru_id     Int
  jam_mulai   DateTime @db.Time(6)
  jam_selesai DateTime @db.Time(6)

  kelas          Kelas                @relation(fields: [kelas_id], references: [id], onDelete: Restrict)
  mata_pelajaran MataPelajaran        @relation(fields: [mapel_id], references: [id], onDelete: Restrict)
  guru           Guru                 @relation(fields: [guru_id], references: [id], onDelete: Restrict)
  detail_absensi DetailAbsensiSiswa[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([kelas_id, hari, jam_mulai])
  @@index([guru_id, hari])
  @@index([mapel_id])
  @@index([deleted_at])
  @@map("jadwal")
}

model MataPelajaran {
  id         Int    @id @default(autoincrement())
  nama_mapel String @db.VarChar(100)

  jadwal Jadwal[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@index([deleted_at])
  @@map("mata_pelajaran")
}

model Kelas {
  id              Int    @id @default(autoincrement())
  kelas           String @db.VarChar(10)
  jurusan_id      Int
  tahun_ajaran_id Int

  jurusan Jurusan  @relation(fields: [jurusan_id], references: [id], onDelete: Restrict)
  tahun   Tahun    @relation(fields: [tahun_ajaran_id], references: [id], onDelete: Restrict)
  siswa   Siswa[]
  jadwal  Jadwal[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@unique([kelas, jurusan_id, tahun_ajaran_id])
  @@index([jurusan_id])
  @@index([tahun_ajaran_id])
  @@index([deleted_at])
  @@map("kelas")
}

model Jurusan {
  id           Int    @id @default(autoincrement())
  nama_jurusan String @unique @db.VarChar(100)

  kelas Kelas[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@index([deleted_at])
  @@map("jurusan")
}

model Tahun {
  id           Int     @id @default(autoincrement())
  tahun_ajaran String  @unique @db.VarChar(20)
  is_active    Boolean @default(false)

  kelas Kelas[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  @@index([is_active])
  @@index([deleted_at])
  @@map("tahun_ajaran")
}
